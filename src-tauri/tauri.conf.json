{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Work Traffic Light",
  "version": "0.1.0",
  "identifier": "cn.openclaw.aiworktrafficlight",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "node tools/dev-server.mjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "light",
        "title": "AI Work Traffic Light",
        "url": "index.html",
        "width": 99,
        "height": 33,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "focus": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
